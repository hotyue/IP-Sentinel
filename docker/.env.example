# ==========================================
# IP-Sentinel Docker 环境变量配置示例
# ==========================================
# 复制此文件为 .env 并填入您的配置
# cp .env.example .env

# ==========================================
# Master (司令部) 配置
# ==========================================

# Telegram Bot Token (必需)
# 从 @BotFather 获取
TG_TOKEN=your_telegram_bot_token_here

# Master 服务端口 (默认: 8080)
MASTER_PORT=8080

# ==========================================
# Agent (边缘哨兵) 配置
# ==========================================

# 节点区域代码 (如: US, JP, SG, HK, UK, DE, FR)
# 参考: data/map.json
REGION_CODE=US

# 绑定到特定IP (留空则自动检测)
BIND_IP=

# Telegram Chat ID (用于接收报告)
CHAT_ID=your_chat_id_here

# Agent Webhook 端口 (默认: 9527)
AGENT_PORT=9527

# 功能开关
ENABLE_GOOGLE=true
ENABLE_TRUST=true